# ============================================================================
# Infinity Exports ERP — Environment Variables
# Copy this file to `.env.local` for local development.
# In Vercel, add these under Project Settings → Environment Variables.
# ============================================================================

# --- Supabase (public — safe to expose to the browser) ---------------------
# Found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (SECRET — server-side only, NEVER expose to the browser) ------
# Service role key bypasses Row Level Security. It is used ONLY inside
# server-side API routes for admin operations (create users, admin queries).
# Do NOT prefix with NEXT_PUBLIC_. Keep this out of client bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Application config -----------------------------------------------------
# Synthetic email domain used to map usernames to Supabase Auth accounts.
# Users log in with a username only; internally it becomes
# `<username>@<AUTH_EMAIL_DOMAIN>`. Keep this stable once users exist.
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=infinityexports.local

# Hard session lifetime in hours. Users and admins are force-signed-out
# after this many hours regardless of activity. Default: 6.
NEXT_PUBLIC_SESSION_MAX_HOURS=6
